import { Theme } from "theme.slint";

export component Layout inherits Window {
    // Vue Props
    in property <string> view: "Player";
    
    // Application State from Rust
    in property <string> time-string: "12:00 PM";
    in property <int> battery-level: 5;
    in property <string> bluetooth-status: "disconnected";

    width: 400px;
    height: 600px;
    background: Theme.base-100;

    VerticalLayout {
        // --- HEADER BAR ---
        HeaderBar := HorizontalLayout {
            vertical-alignment: center;
            height: 30px;
            padding-left: Theme.space-md;
            padding-right: Theme.space-md;

            // Time Label
            Text {
                text: root.time-string;
                font-size: 14px;
                color: Theme.base-content;
                vertical-alignment: center;
            }

            // Current View Title (.application)
            Text {
                text: root.view;
                font-size: 14px;
                color: Theme.base-content;
                opacity: 0.5;
                padding-left: Theme.space-sm;
                vertical-alignment: center;
            }

            // Flex Spacer (equivalent to margin: auto)
            Rectangle {}

            // Bluetooth Icon Asset
            Image {
                // Dynamically resolve image assets based on path strings
                source: @image-url("assets/bluetooth.png");
                width: 22px;
                height: 22px;
                
                // Emulating CSS keyframe animation via Slint state cycles
                opacity: root.bluetooth-status == "disconnected" ? (AnimationDriver.pulse-toggle ? 1.0 : 0.25) : 1.0;
                
                animate opacity {
                    duration: 750ms;
                }
            }

            // Battery Icon Asset
            Image {
                // Matches :name="`battery/${battery}`"
                source: root.battery-level == 1 ? @image-url("assets/battery/1.png") :
                        root.battery-level == 2 ? @image-url("assets/battery/2.png") :
                        root.battery-level == 3 ? @image-url("assets/battery/3.png") :
                        root.battery-level == 4 ? @image-url("assets/battery/4.png") :
                                                  @image-url("assets/battery/5.png");
                width: 22px;
                height: 22px;
                
                // .empty-battery-fix (translateY)
                y: root.battery-level == 1 ? -1px : 0px; 
            }
        }

        // --- MAIN SLOT CONTENT ---
        @children
    }
}

// Global driver helper to run the infinite pulse loop natively in UI thread
global AnimationDriver {
    in-out property <bool> pulse-toggle: false;
}
