export global Theme {
    // === Core Brand Colors ===
    in-out property <color> primary: #7480ff;          // Bright blue-indigo
    in-out property <color> primary-content: #050616;  // Near black text on primary
    
    in-out property <color> secondary: #ff52d9;        // Vibrant pink
    in-out property <color> secondary-content: #160211;// Dark text on secondary
    
    in-out property <color> accent: #00cdb8;           // Teal / Cyan
    in-out property <color> accent-content: #000f0c;    // Dark text on accent
    
    in-out property <color> neutral: #2a323c;          // Deep grey for cards/chips
    in-out property <color> neutral-content: #a6adbb;  // Muted silver text on neutral

    // === Layered Surface Backgrounds ===
    in-out property <color> base-100: #1d232a;         // Main application canvas window
    in-out property <color> base-200: #191e24;         // Sub-sections, sidebars, panels
    in-out property <color> base-300: #15191e;         // Extra deep contrast layer (inputs/wells)
    in-out property <color> base-content: #a6adbb;     // Default body text color

    // === State & Feedback Colors ===
    in-out property <color> info: #00b5ff;
    in-out property <color> success: #00a96e;
    in-out property <color> warning: #ffbe00;
    in-out property <color> error: #ff5861;

    // === Layout & Sizing Defaults ===
    in-out property <length> border-radius: 8px;
    in-out property <length> space-xs: 4px;
    in-out property <length> space-sm: 8px;
    in-out property <length> space-md: 16px;
    in-out property <length> space-lg: 24px;
}